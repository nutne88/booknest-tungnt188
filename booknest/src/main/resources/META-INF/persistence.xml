<?xml version="1.0" encoding="UTF-8"?>
<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             version="3.1">
    <persistence-unit name="bookNestPU">
        <class>com.booknest.domain.Book</class>
        <class>com.booknest.domain.Author</class>
        <class>com.booknest.domain.Category</class>
        <class>com.booknest.domain.Member</class>
        <class>com.booknest.domain.MemberProfile</class>
        <class>com.booknest.domain.Loan</class>
        <class>com.booknest.domain.LoanItem</class>

        <properties>
            <property name="jakarta.persistence.jdbc.driver" value="org.h2.Driver"/>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:h2:file:./data/booknestdb;AUTO_SERVER=TRUE"/>
            <property name="jakarta.persistence.jdbc.user" value="sa"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="hibernate.dialect" value="org.hibernate.dialect.H2Dialect"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
            <property name="hibernate.highlight_sql" value="true"/>
            <property name="hibernate.default_batch_fetch_size" value="20"/>
        </properties>
    </persistence-unit>
</persistence>
